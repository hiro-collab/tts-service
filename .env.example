# tts_service local settings
#
# The MVP uses Windows System.Speech through PowerShell and does not require
# any API key.

TTS_SERVICE_STATUS_DIR=.cache/tts_service
TTS_SERVICE_POLL_INTERVAL=1.0
TTS_SERVICE_SAPI_VOICE=
TTS_SERVICE_SAPI_RATE=0
TTS_SERVICE_SAPI_VOLUME=100

# Future adapters only. Do not commit real secrets.
OPENAI_API_KEY=
VOICEVOX_ENDPOINT=http://127.0.0.1:50021
